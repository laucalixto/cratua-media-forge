{
  "name": "mediaforge-tauri",
  "private": true,
  "version": "0.3.6",
  "scripts": {
    "dev": "V=$(node -p \"require('./package.json').version\") && sed -i \"s/v__VERSION__\\|v[0-9]\\+\\.[0-9]\\+\\.[0-9]\\+/v$V/\" ui/index.html && esbuild ui/src/main.js --bundle --outfile=ui/bundle.js --servedir=ui --serve=localhost:1420",
    "build": "V=$(node -p \"require('./package.json').version\") && sed -i \"s/v__VERSION__\\|v[0-9]\\+\\.[0-9]\\+\\.[0-9]\\+/v$V/\" ui/index.html && esbuild ui/src/main.js --bundle --minify --outfile=ui/bundle.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1"
  }
}
