{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Cratua Media Forge",
  "version": "0.3.9",
  "identifier": "com.cratua.mediaforge",
  "build": {
    "frontendDist": "./ui",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cratua Media Forge",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "windows": {
      "wix": null,
      "nsis": null,
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
